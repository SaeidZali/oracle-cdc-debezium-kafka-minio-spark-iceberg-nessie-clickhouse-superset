{
  "name": "minio-s3-sink",
  "config": {
    "connector.class": "io.confluent.connect.s3.S3SinkConnector",
    "tasks.max": "1",
    "topics": "server1.C__DBZUSER.CUSTOMERS",

    "s3.bucket.name": "oracle-cdc",
    "s3.region": "us-east-1",

    "store.url": "http://minio:9000",
    "s3.path.style.access.enabled": "true",

    "aws.access.key.id": "minioadmin",
    "aws.secret.access.key": "minioadmin",

    "storage.class": "io.confluent.connect.s3.storage.S3Storage",
    "format.class": "io.confluent.connect.s3.format.parquet.ParquetFormat",

    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://schema-registry:8081",

    "schema.compatibility": "NONE",
    "partitioner.class": "io.confluent.connect.storage.partitioner.DefaultPartitioner",
    "flush.size": "100000",
    "rotate.interval.ms": "1000",
    "behavior.on.null.values": "ignore",

    "value.converter.schema.read": "true",
    "transforms": "openlineage",
    "transforms.openlineage.type": "io.factorhouse.openlineage.kafka.OpenLineageLifecycleSmt",
    "openlineage.dataset.namespace": "s3://minio:9000/oracle-cdc",
    "openlineage.namespace": "fh-local",
    "openlineage.kafka.bootstrap.servers": "kafka:9092",
    "openlineage.schema.registry.url": "http://schema-registry:8081",
    "openlineage.marquez.url": "http://marquez:5000",
    "tasks.max": "1"
  }
}
